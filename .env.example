# LINGNEXUS — 环境变量模板
# 复制此文件为 .env 并填入真实值

# ══════════════════════════════════════════════════════════════
#  Anthropic — 使用 Claude Code 订阅凭证（main / validator）
#  直接从 Claude Code 的 session-env 复用，无需另购 API Key
# ══════════════════════════════════════════════════════════════

# Claude Code 的 OAuth Token（cr_ 开头）
ANTHROPIC_OAUTH_TOKEN=cr_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude Code 的代理端点
ANTHROPIC_BASE_URL=https://claude-code.club/api

# ══════════════════════════════════════════════════════════════
#  第三方模型 API Keys
# ══════════════════════════════════════════════════════════════

# Moonshot AI / Kimi（coach）
# 获取: https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google AI Studio（investigator）
# 获取: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter（deduplicator — 调用 Qwen）
# 获取: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ══════════════════════════════════════════════════════════════
#  各 Agent 模型分配
# ══════════════════════════════════════════════════════════════

MODEL_MAIN=claude-haiku-4-5-20251001
MODEL_COACH=kimi-coding/kimi-k2-thinking
MODEL_INVESTIGATOR=google/gemini-2.5-flash
MODEL_VALIDATOR=claude-sonnet-4-6
MODEL_DEDUPLICATOR=openrouter/qwen/qwen3.5-27b

# ══════════════════════════════════════════════════════════════
#  可选配置
# ══════════════════════════════════════════════════════════════

OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_LOG_LEVEL=info
